NODE_ENV=development
PORT=3001
DB_PATH=./ticker.db

# Use a long random value in production.
JWT_SECRET=change_me_to_a_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7
BCRYPT_COST=12

# Optional comma-separated origins. Use same-origin by default.
# CORS_ORIGIN=https://your-domain.example

RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
API_RATE_LIMIT_MAX=100

# Optional live provider mode. Default is false for reliable demos.
# Uses CoinGecko for crypto, Frankfurter for forex, Yahoo quote endpoint for US stocks.
LIVE_MARKET_DATA=false
LIVE_MARKET_INTERVAL_MS=30000
MARKET_PROVIDER_TIMEOUT_MS=4000
